<!DOCTYPE html>
<html>
  <head>
    <title>Myapp</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- フラッシュメッセージの表示（ここだけに記述） -->
    <% if flash[:notice] %>
      <div style="color: green; margin-bottom: 20px; border: 2px solid green; padding: 10px; background-color: #d4edda; border-radius: 5px;">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div style="color: red; margin-bottom: 20px; border: 2px solid red; padding: 10px; background-color: #f8d7da; border-radius: 5px;">
        <%= flash[:alert] %>
      </div>
    <% end %>
    
    <%= yield %>
  </body>
</html>
