
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>しりとりゲーム</title>
  <%= stylesheet_link_tag 'application', media: 'all' %>
</head>
<body>
  <div class="container">
  <h1>しりとりゲーム</h1>
  <p> 一文字につき10点加算されます。</p>
  <p>10個の単語でなるべく多くの得点をめざそう</p>

  <!-- スコア表示 -->
  <div class="score-board">
    <p>総スコア: <%= @total_score %>点　　　単語数: <%= @words.count %> / 10</p>
  </div>

<% if @words.any? && @words.count < 10 %>
  <div style="margin-bottom: 20px;">
    <p>最後の単語：<strong><%= @words.last.content %></strong></p>
    <p style="color: #0066cc; font-size: 18px; font-weight: bold;">
      次は「<%= @words.last.last_char_for_shiritori %>」で始まる単語を入力してください
    </p>
  </div>
<% end %>

  <%# フラッシュメッセージの表示は無し %>

<%# エラーメッセージの表示 %>
<% if @word.errors&.any? %>
  <div style="color: red; margin-bottom: 20px; border: 2px solid red; padding: 10px;">
    <h3>エラーが発生しました：</h3>
    <ul>
      <% @word.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>


  <!-- 単語リスト -->
  <div class="words-list">
    <% @words.each_with_index do |word, index| %>
      <div class="word-item">
        <span><%= index + 1 %>.</span>
        <span><%= word.content %></span>
      </div>
    <% end %>
  </div>
  
<!-- 入力フォーム（10単語未満の場合のみ表示） -->
<% if @words.count < 10 %>
  <%= form_with model: [@game, @word], url: words_path, local: true do |f| %>
  <%= f.text_field :content, placeholder: "単語を入力" %>
  <%= f.submit "追加" %>
<% end %>
<% end %>
  
<!-- 10個達成メッセージ -->
<% if @words.count >= 10 %>
  <div class="congratulations">
    <p>Congratulations！　　総スコア：<%= @total_score %>点</p>

    <%= link_to 'Xでシェア',
          x_share_url(@total_score),
          target: '_blank',
          rel: 'noopener',
          class: 'share-button' %>

    <%= button_to 'もう一度遊ぶ',
          reset_words_path,
          method: :delete,
          class: 'reset-button' %>
  </div>
<% end %>


  <!-- リセットボタン -->
  <%= button_to 'リセット', reset_words_path, method: :delete, 
      data: { confirm: '本当にリセットしますか？' } %>
</div>
</div>
</body>
</html>

